  <property name="styleSheet">
   <string notr="true">/* ========================================
   STYLESHEET SECTION - Professional Gradient Theme
   Theme Colors: Purple/Blue Gradient (#667eea, #764ba2)
   Dark Background: #0f1419, #1a202c, #2d3748
   ======================================== */

/* Main Window */
QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #0f1419, stop:1 #1a1f2e);
}

/* Labels */
QLabel {
    color: #e4e8f0;
    font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    font-size: 12px;
}

/* Buttons */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1f1f3d, stop:1 #0f0f25);
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 600;
    min-height: 16px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #2d2d5f, stop:1 #1a1a38);
    border: 2px solid #764ba2;
    color: #ffffff;
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #7c3aed;
    color: #ffffff;
}

QPushButton#btnUploadOriginal {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
    color: #ffffff;
}

QPushButton#btnUploadOriginal:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #764ba2, stop:1 #9333ea);
    border: 2px solid #7c3aed;
    color: #ffffff;
}

/* Input Fields */
QLineEdit, QComboBox {
    background-color: #1a202c;
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 6px;
    padding: 5px 8px;
    font-size: 11px;
    selection-background-color: #764ba2;
}

QLineEdit:focus, QComboBox:focus {
    border: 2px solid #764ba2;
    background-color: #1f2937;
}

QComboBox::drop-down {
    border: none;
    padding-right: 10px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #667eea;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: #1a202c;
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 8px;
    selection-background-color: #667eea;
    padding: 4px;
}

/* Group Boxes */
QGroupBox {
    color: #e4e8f0;
    border: 2px solid #667eea;
    border-radius: 12px;
    margin-top: 12px;
    font-weight: 600;
    font-size: 13px;
    padding: 10px 8px 8px 8px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #1a1a36, stop:1 #0f0f1f);
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 3px 12px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border-radius: 6px;
    color: #ffffff;
    font-weight: bold;
    font-size: 12px;
}

/* Checkboxes */
QCheckBox {
    color: #e4e8f0;
    font-size: 12px;
    spacing: 8px;
    padding: 4px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #667eea;
    border-radius: 6px;
    background-color: #1a202c;
}

QCheckBox::indicator:hover {
    border: 2px solid #764ba2;
    background-color: #1f2937;
}

QCheckBox::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
    image: none;
}

QCheckBox::indicator:checked:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #764ba2, stop:1 #9333ea);
}

/* Radio Buttons */
QRadioButton {
    color: #e4e8f0;
    font-size: 12px;
    spacing: 8px;
    padding: 4px;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #667eea;
    border-radius: 9px;
    background-color: #1a202c;
}

QRadioButton::indicator:hover {
    border: 2px solid #764ba2;
    background-color: #1f2937;
}

QRadioButton::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
}

QRadioButton::indicator:checked:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
                                stop:0 #764ba2, stop:1 #9333ea);
}

/* Sliders */
QSlider::groove:horizontal {
    background: #1a202c;
    height: 8px;
    border-radius: 4px;
    border: 1px solid #667eea;
}

QSlider::handle:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border: 2px solid #5a67d8;
    width: 18px;
    margin: -6px 0;
    border-radius: 9px;
}

QSlider::handle:horizontal:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #764ba2, stop:1 #9333ea);
    border: 2px solid #7c3aed;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border-radius: 4px;
}

/* Scroll Area */
QScrollArea {
    border: none;
    background: transparent;
}

QScrollBar:vertical {
    background-color: #0f0f25;
    width: 12px;
    border-radius: 6px;
}

QScrollBar::handle:vertical {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #667eea, stop:1 #764ba2);
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                stop:0 #764ba2, stop:1 #9333ea);
}

/* Settings Container */

QFrame#settingsContainer {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #0f1419, stop:0.5 #1a1a36, stop:1 #0f0f1f);
    border: none;
    border-top: 2px solid #667eea;
    border-radius: 0px;
    margin-left: -16px;
    margin-right: -16px;
    margin-bottom: -16px;
    padding: 16px;
}</string>
