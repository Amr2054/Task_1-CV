     <!-- ========================================
              PAGE 3: Frequency Domain & Hybrid Mode
              Contains: Low Pass, High Pass filters + Hybrid image generation
              ======================================== -->
        <widget class="QWidget" name="frequencyPage">
            <layout class="QVBoxLayout" name="verticalLayout_freqOuter">
            <property name="spacing"><number>16</number></property>

            <!-- Vertical spacer top -->
            <item>
            <spacer name="verticalSpacerFreqTop">
                <property name="orientation"><enum>Qt::Vertical</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
            </spacer>
            </item>

            <!-- Three image boxes -->
            <item>
            <layout class="QHBoxLayout" name="horizontalLayout_freqBoxes">
                <property name="spacing"><number>24</number></property>

                <!-- Horizontal spacer left -->
                <item>
                <spacer name="horizontalSpacerFreqLeft">
                <property name="orientation"><enum>Qt::Horizontal</enum></property>
                <property name="sizeHint" stdset="0"><size><width>20</width><height>20</height></size></property>
                </spacer>
                </item>

                <!-- Left column: Low Pass (top) + High Pass (bottom) -->
                <item>
                <layout class="QVBoxLayout" name="verticalLayout_freqLeft">
                <property name="spacing"><number>16</number></property>

                <!-- Low Pass box -->
                <item>
                <widget class="QGroupBox" name="freqLowPassGroup">
                    <property name="title"><string>Low Freq Only</string></property>
                    <layout class="QVBoxLayout" name="vlFreqLow">
                    <item>
                    <widget class="QLabel" name="imgFreqLowPass">
                    <property name="minimumSize"><size><width>420</width><height>260</height></size></property>
                    <property name="styleSheet">
                        <string notr="true">background:#0f0f25; border:2px solid #667eea; border-radius:8px; color:#8892b0; font-size:12px;</string>
                    </property>
                    <property name="text"><string>Upload image to apply Low Pass</string></property>
                    <property name="alignment"><set>Qt::AlignCenter</set></property>
                    </widget>
                    </item>
                    <item>
                    <widget class="QPushButton" name="btnUploadLowPass">
                    <property name="text"><string>Upload Image (Low Pass)</string></property>
                    </widget>
                    </item>
                    </layout>
                </widget>
                </item>

                <!-- High Pass box -->
                <item>
                <widget class="QGroupBox" name="freqHighPassGroup">
                    <property name="title"><string>High Freq Only</string></property>
                    <layout class="QVBoxLayout" name="vlFreqHigh">
                    <item>
                    <widget class="QLabel" name="imgFreqHighPass">
                    <property name="minimumSize"><size><width>420</width><height>260</height></size></property>
                    <property name="styleSheet">
